VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Copy this file to .env and paste your real EmailJS IDs (Vite does NOT read .env.example).
# copy .env.example .env
#
# EmailJS template: To Email = Sales@infinityforwarder.com (or {{to_email}})
# Reply To = {{reply_to}} or {{email}} | From Name = {{from_name}} or {{name}}
VITE_EMAILJS_TO_EMAIL=Sales@infinityforwarder.com
